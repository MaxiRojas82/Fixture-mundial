# Clave de football-data.org (gratuita en https://www.football-data.org/client/register)
FOOTBALL_API_KEY=tu_clave_de_football_data_org

# Clave de Google Gemini para análisis IA (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_clave_de_gemini

# ID de competición del Mundial FIFA en football-data.org
# 2000 = FIFA World Cup (verificar para la edición 2026)
WORLD_CUP_COMPETITION_ID=2000

# Intervalo de polling en segundos para partidos en vivo
POLL_INTERVAL_SECONDS=30
